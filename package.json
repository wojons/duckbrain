{
  "name": "duckbrain",
  "version": "1.0.0",
  "description": "AI Memory System - MCP server with persistent, version-controlled memory",
  "main": "index.js",
  "bin": {
    "duckbrain": "./bin/duckbrain.js"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts tests/",
    "test:http": "vitest run --config vitest.integration.config.ts tests/http-auth.int.test.ts tests/http-e2e.int.test.ts tests/rate-limit.int.test.ts",
    "start": "node bin/duckbrain.js",
    "start:http": "node bin/duckbrain.js http --port 9444",
    "start:ui": "npm run dev --prefix packages/ui",
    "dev": "concurrently \"npm run start:http\" \"npm run start:ui\"",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up",
    "build": "npm run build --prefix packages/ui",
    "docker:build": "docker build -t duckbrain .",
    "docker:run": "docker run -p 9444:9444 -p 5173:5173 -v duckbrain-data:/data duckbrain",
    "stop": "pkill -f 'duckbrain.*http' || true; pkill -f 'vite' || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wojons/duckbrain.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/wojons/duckbrain/issues"
  },
  "homepage": "https://github.com/wojons/duckbrain#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "async-mutex": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "duckdb": "1.4.4",
    "simple-git": "^3.36.0",
    "tsx": "^4.23.1",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.5",
    "@types/uuid": "^11.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  }
}
