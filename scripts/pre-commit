#!/bin/sh
# Pre-commit hook — runs gitleaks + tests + lint
# Repo-agnostic: adapts to what's in the repo.
# Install: scripts/install-hooks.sh

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

HAS_ERROR=0

# ─────────────────────────────────────────────
# 1. GITLEAKS — secret scanning (staged files only)
# ─────────────────────────────────────────────
if command -v gitleaks >/dev/null 2>&1; then
    # Get list of staged files (added, copied, modified — not deleted)
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
    
    if [ -n "$STAGED_FILES" ]; then
        echo "${GREEN}=== 🔐 Gitleaks: Scanning staged files for secrets ===${NC}"
        # Scan only the staged files — not the whole repo (which may have gitignored local configs)
        echo "$STAGED_FILES" | xargs -r -I{} gitleaks detect --no-git --source "{}" --verbose --redact --no-banner 2>&1
        if [ $? -ne 0 ]; then
            echo ""
            echo "${RED}❌ GITLEAKS FOUND SECRETS IN STAGED FILES${NC}"
            echo "${RED}   Commit blocked. Review findings above.${NC}"
            echo "${RED}   Emergency bypass: git commit --no-verify${NC}"
            HAS_ERROR=1
        else
            echo "${GREEN}✅ No secrets detected${NC}"
        fi
    else
        echo "${GREEN}=== 🔐 Gitleaks: No staged files to scan ===${NC}"
    fi
else
    echo "${YELLOW}⚠️  gitleaks not installed — skipping secret scan${NC}"
    echo "${YELLOW}   Install: go install github.com/gitleaks/gitleaks/v8@latest${NC}"
fi

# ─────────────────────────────────────────────
# 2. UNIT TESTS (if tests/ exists)
# ─────────────────────────────────────────────
if [ -d "tests" ] && [ -f "$(which python3 2>/dev/null || which python 2>/dev/null)" ]; then
    echo ""
    echo "${GREEN}=== 🧪 Unit Tests ===${NC}"
    if python -m pytest tests/unit/ -v --tb=short -q 2>&1; then
        echo "${GREEN}✅ Tests passed${NC}"
    else
        echo ""
        echo "${RED}❌ Unit tests failed${NC}"
        HAS_ERROR=1
    fi
fi

# ─────────────────────────────────────────────
# 3. LINT (if Python files exist outside tests)
# ─────────────────────────────────────────────
PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | grep -v '^tests/' | head -20)
if [ -n "$PY_FILES" ]; then
    echo ""
    echo "${GREEN}=== 📝 Python Syntax Check ===${NC}"
    echo "$PY_FILES" | while IFS= read -r f; do
        if [ -f "$f" ]; then
            python -m py_compile "$f" || HAS_ERROR=1
        fi
    done
    echo "${GREEN}✅ Syntax OK${NC}"
fi

# ─────────────────────────────────────────────
echo ""
if [ "$HAS_ERROR" -eq 0 ]; then
    echo "${GREEN}✅ All pre-commit checks passed${NC}"
    exit 0
else
    echo "${RED}❌ Pre-commit checks failed — commit aborted${NC}"
    exit 1
fi
