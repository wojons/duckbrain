# DuckBrain Environment Configuration
# Copy this file to .env and customize for your setup

# =============================================================================
# Required Configuration
# =============================================================================

# Project namespace for memory isolation
# Each namespace gets its own git repository
DUCKBRAIN_NAMESPACE=default

# =============================================================================
# Optional Configuration
# =============================================================================

# Data directory for memory storage
# Default: ./memory (relative to working directory)
DUCKBRAIN_DATA_DIR=./memory

# API Server Configuration
DUCKBRAIN_API_PORT=8490
DUCKBRAIN_API_HOST=localhost

# Web UI Configuration  
DUCKBRAIN_UI_PORT=8989

# Git Configuration
DUCKBRAIN_GIT_REMOTE=origin

# Logging
# Options: debug, info, warn, error
DUCKBRAIN_LOG_LEVEL=info

# =============================================================================
# Development Settings
# =============================================================================

# Node environment
NODE_ENV=development

# =============================================================================
# Security (for HTTP mode)
# =============================================================================

# API Authentication Token (generate with: openssl rand -base64 32)
# DUCKBRAIN_API_TOKEN=your-secure-token-here

# Rate Limiting
# DUCKBRAIN_RATE_LIMIT_ENABLED=true
# DUCKBRAIN_RATE_LIMIT_MAX=100
